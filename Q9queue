#include <iostream>
using namespace std;

#define SIZE 5

int q[SIZE];
int front = -1, rear = -1;

// Enqueue
void enqueue(int x) {
    if ((rear + 1) % SIZE == front) {
        cout << "Queue Full\n";
        return;
    }

    if (front == -1) {
        front = rear = 0;
    } else {
        rear = (rear + 1) % SIZE;
    }

    q[rear] = x;
    cout << x << " inserted\n";
}

// Dequeue
void dequeue() {
    if (front == -1) {
        cout << "Queue Empty\n";
        return;
    }

    cout << q[front] << " deleted\n";

    if (front == rear) {
        front = rear = -1;
    } else {
        front = (front + 1) % SIZE;
    }
}

// Display
void display() {
    if (front == -1) {
        cout << "Queue Empty\n";
        return;
    }

    cout << "Queue: ";
    int i = front;

    while (i != rear) {
        cout << q[i] << " ";
        i = (i + 1) % SIZE;
    }
    cout << q[rear] << endl;
}

// Main
int main() {
    int choice, value;

    do {
        cout << "\n--- Circular Queue Menu ---\n";
        cout << "1. Enqueue\n";
        cout << "2. Dequeue\n";
        cout << "3. Display\n";
        cout << "4. Exit\n";
        cout << "Enter choice: ";
        cin >> choice;

        switch (choice) {
            case 1:
                cout << "Enter value: ";
                cin >> value;
                enqueue(value);
                break;

            case 2:
                dequeue();
                break;

            case 3:
                display();
                break;

            case 4:
                cout << "Program Ended\n";
                break;

            default:
                cout << "Invalid choice\n";
        }

    } while (choice != 4);

    return 0;
}
